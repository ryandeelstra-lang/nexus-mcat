# charged_up: copy this file to `.env` (git-ignored) and fill in a key.
# Build-time generation scripts (scripts/gen_spoken_variants.py) read `.env`
# from the repo root; existing shell environment variables win over this file.
#
# Either key works for the spoken-variants generator — Anthropic is preferred
# when both are set. The app itself only ever reads real environment variables.

# OpenAI (also enables hosted STT when VOICE_STT_HOSTED=1 at app runtime)
OPENAI_API_KEY=

# Anthropic (also enables the semantic voice grader at app runtime)
ANTHROPIC_API_KEY=

# Optional model overrides for the variants generator
# VOICE_VARIANT_MODEL=claude-sonnet-4-5
# VOICE_VARIANT_OPENAI_MODEL=gpt-4o-mini
